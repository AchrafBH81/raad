   -
     name : _Init
     procedure_id : 1467015460854427412
     type_code : 12
     code : |1+
      
      procédure PRIVÉE _Init()
      
      
      // 1. Initialisation de la structure (Point de départ unique)
      m_structureProjet = new CLGestionnaireStructureProjet
      
      
      
      // 2. Initialisation du service de Log (Nécessite le répertoire Log de la structure)
      m_log = new CLlog
      // Imaginons une méthode d'initialisation pour le log
      // m_log.Initialiser(m_structureProjet.P_RepLog())
      
      
      
      // 3. Initialisation du Gestionnaire de VHost
      m_GestionnaireVHost = new CLGestionnaireVHost
      // On utilise P_RepConf() pour localiser le fichier de configuration [cite: 119, 120]
      m_GestionnaireVHost.Initialisation(m_structureProjet.P_RepConf + "\vhosts.conf", m_log)
      
      
      m_system			= new CLSysteme
      
      
      //Fichier de configuration
      m_FichierIni		= new CLIniFichier
      m_FichierIni.Initialisation(m_structureProjet.P_RepConf + "\config.conf",m_log) 
      
      //BDD
      m_Base = new CLBase
      m_Base.Initialisation(m_FichierIni,m_log)
      
      //socket 
      m_ServeurSocket								= new CLServeurSocket
      m_ServeurSocket.m_Proc_CallBack				= MessageRecu
      
      m_ServeurSocket.P_PortSocket					= Val(m_FichierIni.LireEcrireClé("Serveur","Port",8080))
      m_ServeurSocket.p_NomSocketEcoute			= "SocketRaaD"
     type : 458752
   -
     name : _GetRecord
     procedure_id : 1473736444733868589
     type_code : 12
     code : |1+
      procédure prive _GetRecord(l_HttpReq est CLSocketCanal)
      
      // Affectation par copie 
      
      L_record est  CLRecord
      L_record <= m_Base.m_Table[l_HttpReq.m_Parametres["table"]]
      
      L_record.Load(l_HttpReq.m_Parametres["valkey"],l_HttpReq.m_Parametres["condition"])
      
      si L_record.m_erreur <> "" ALORS
      	l_HttpReq.m_CodeReponse		= "401"
      	l_HttpReq.m_ContenuBuffer	= L_record.m_erreur
      sinon
      	l_HttpReq.m_CodeReponse = "200 OK"
      	l_HttpReq.m_ContenuBuffer = L_record.m_json
      FIN
      
      
      
     type : 458752
   -
     name : _ExecuteSql
     procedure_id : 1473738635167241172
     type_code : 12
     code : |1+
      procédure Privé _ExecuteSql(l_HttpReq est CLSocketCanal)
      
      
      l_base est CLBase dynamique = allouer CLBase
      l_base <= m_Base
      
      Chainereq est chaine 
      Chainereq = l_HttpReq.m_Parametres["sql"]
      
      l_HttpReq.m_CodeReponse = "200 OK"
     type : 458752

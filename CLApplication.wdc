   -
     name : _ModifierEnregistrement
     procedure_id : 1515318213611328442
     type_code : 12
     code : |1-
      procédure privée _ModifierEnregistrement(L_RequeteHttp est CLCanalSocket)
      
      L_EnregistrementCourant est un clenregistrement dynamique = allouer un clenregistrement
      L_EnregistrementCourant <= m_Base.m_Table[L_RequeteHttp.m_Parametres["table"]]
      
      L_EnregistrementCourant.m_json = L_RequeteHttp.m_CorpsRequete
      L_EnregistrementCourant.Modifier()
      
      SI L_EnregistrementCourant.m_erreur <> "" ALORS
      	L_RequeteHttp.m_CodeReponse		= "401"
      	L_RequeteHttp.m_ContenuBuffer	= L_EnregistrementCourant.m_erreur
      SINON
      	L_RequeteHttp.m_CodeReponse		= "200 OK"
      	L_RequeteHttp.m_ContenuBuffer	= L_EnregistrementCourant.m_json
      FIN
      
      libérer L_EnregistrementCourant
     type : 458752
   -
     name : _CreerEnregistrement
     procedure_id : 1521641157040203827
     type_code : 12
     code : |1+
      procédure privée _CreerEnregistrement(L_RequeteHttp est CLCanalSocket)
      
      // Déclaration d'une instance locale au thread.
      // L'utilisation de l'opérateur '<=' effectue une affectation par copie (et non par référence).
      // Cela permet de cloner l'objet "prototype" préchargé dans m_Base.m_Table afin 
      // d'obtenir une instance physiquement indépendante et propre à cette requête HTTP.
      // Cela garantit que les données (ex: m_json, m_erreur) ne s'écrasent pas entre deux clients simultanés (Thread-Safe).
      
      // On alloue une VRAIE nouvelle instance totalement isolée en mémoire
      L_EnregistrementCourant est un clenregistrement dynamique = allouer un clenregistrement
      L_EnregistrementCourant <= m_Base.m_Table[L_RequeteHttp.m_Parametres["table"]]
      
      
      
      L_EnregistrementCourant.m_json = L_RequeteHttp.m_CorpsRequete
      L_EnregistrementCourant.Creer()
      
      SI L_EnregistrementCourant.m_erreur <> "" ALORS
      	L_RequeteHttp.m_CodeReponse		= "401"
      	L_RequeteHttp.m_ContenuBuffer	= L_EnregistrementCourant.m_erreur
      SINON
      	L_RequeteHttp.m_CodeReponse		= "200 OK"
      	L_RequeteHttp.m_ContenuBuffer	= L_EnregistrementCourant.m_json
      FIN
      
      libérer L_EnregistrementCourant
     type : 458752

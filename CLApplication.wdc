   -
     name : _UpdateRecord
     procedure_id : 1515318213611328442
     type_code : 12
     code : |1-
      procédure privée _UpdateRecord(l_HttpReq est CLSocketCanal)
      
      L_record est un CLRecord dynamique = allouer un CLRecord
      L_record <= m_Base.m_Table[l_HttpReq.m_Parametres["table"]]
      
      L_record.m_json = l_HttpReq.m_CorpReq
      L_record.Update()
      
      SI L_record.m_erreur <> "" ALORS
      	l_HttpReq.m_CodeReponse		= "401"
      	l_HttpReq.m_ContenuBuffer	= L_record.m_erreur
      SINON
      	l_HttpReq.m_CodeReponse		= "200 OK"
      	l_HttpReq.m_ContenuBuffer	= L_record.m_json
      FIN
      
      libérer L_record
     type : 458752
   -
     name : _CreateRecord
     procedure_id : 1521641157040203827
     type_code : 12
     code : |1+
      procédure privée _CreateRecord(l_HttpReq est CLSocketCanal)
      
      // Déclaration d'une instance locale au thread.
      // L'utilisation de l'opérateur '<=' effectue une affectation par copie (et non par référence).
      // Cela permet de cloner l'objet "prototype" préchargé dans m_Base.m_Table afin 
      // d'obtenir une instance physiquement indépendante et propre à cette requête HTTP.
      // Cela garantit que les données (ex: m_json, m_erreur) ne s'écrasent pas entre deux clients simultanés (Thread-Safe).
      
      // On alloue une VRAIE nouvelle instance totalement isolée en mémoire
      L_record est un CLRecord dynamique = allouer un CLRecord
      L_record <= m_Base.m_Table[l_HttpReq.m_Parametres["table"]]
      
      
      
      L_record.m_json = l_HttpReq.m_CorpReq
      L_record.Create()
      
      SI L_record.m_erreur <> "" ALORS
      	l_HttpReq.m_CodeReponse		= "401"
      	l_HttpReq.m_ContenuBuffer	= L_record.m_erreur
      SINON
      	l_HttpReq.m_CodeReponse		= "200 OK"
      	l_HttpReq.m_ContenuBuffer	= L_record.m_json
      FIN
      
      libérer L_record
     type : 458752

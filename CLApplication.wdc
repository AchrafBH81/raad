   -
     name : MessageRecu
     procedure_id : 1465891540924885333
     type_code : 12
     code : |1+
      
      procédure MessageRecu(SocketRecu est CLCanalSocket) 
      
      SocketRecu.AnalyserRequete()
      
      selon SocketRecu.m_PointDEntree
      	
      	cas "record" : 
      		
      		selon SocketRecu.m_TypeReq
      			
      			cas "GET" : 
      				// Lecture enregistrement
      				_LireEnregistrement(SocketRecu)
      			cas "POST" : 
      				// Création enregistrement
      				_CreerEnregistrement(SocketRecu)
      			cas "PUT"
      				// Modification enregistrement
      				_ModifierEnregistrement(SocketRecu)
      			cas "DELETE"
      				// Suppression enregistrement 
      				_SupprimerEnregistrement(SocketRecu)
      			
      		FIN
      		
      	CAS "records" :
      		
      		_LireEnregistrements(SocketRecu)
      		
      	cas "sql" : 
      		_ExecuterRequeteSQL(SocketRecu)
      		
      	cas "memoire"
      		
      		_GetMemory(SocketRecu)
      		
      	AUTRE CAS : 
      		_ObtenirFichier(SocketRecu)
      		
      		
      FIN
      
      
      
       SocketRecu.GenererReponse()    
      
     type : 458752
   -
     name : Execute
     procedure_id : 1466997623856337504

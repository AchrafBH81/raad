   -
     name : MessageRecu
     procedure_id : 1465891540924885333
     type_code : 12
     code : |1+
      
      procédure MessageRecu(SocketRecu est CLSocketCanal) 
      
      SocketRecu.AnalyseReq()
      
      selon SocketRecu.m_PointDentre
      	
      	cas "record" : 
      		
      		selon SocketRecu.m_TypeReq
      			
      			cas "GET" : 
      				// Lecture enregistrement
      				_GetRecord(SocketRecu)
      			cas "POST" : 
      				// Création enregistrement
      				_CreateRecord(SocketRecu)
      			cas "PUT"
      				// Modification enregistrement
      				_UpdateRecord(SocketRecu)
      			cas "DELETE"
      				// Suppression enregistrement 
      				_DelteRecord(SocketRecu)
      			
      		FIN
      		
      	CAS "records" :
      		
      		_GetRecords(SocketRecu)
      		
      	cas "sql" : 
      		_ExecuteSql(SocketRecu)
      		
      	cas "memoire"
      		
      		_GetMemory(SocketRecu)
      		
      	AUTRE CAS : 
      		_GetFile(SocketRecu)
      		
      		
      FIN
      
      
      
       SocketRecu.GetReponse()    
      
     type : 458752
   -
     name : Execute
     procedure_id : 1466997623856337504
     type_code : 12
     code : |1+
      
      procédure Execute()
      
      
      
      

   -
     name : _Init
     procedure_id : 1467015460854427412
     type_code : 12
     code : |1-
      
      procédure PRIVÉE _Init()
      
      // 1. Initialisation de la structure (Point de départ unique)
      m_structureProjet	= new CLGestionnaireStructureProjet
      // 2. Initialisation du service de Log (Nécessite le répertoire Log de la structure)
      m_Journal				= new CLjournalisation
      // Imaginons une méthode d'initialisation pour le log
      // m_journal.Initialiser(m_structureProjet.P_RepLog())
      
      // 3. Initialisation du Gestionnaire de VHost
      m_GestionnaireVHost	= new CLGestionnaireVHost
      // On utilise P_RepConf() pour localiser le fichier de configuration [cite: 119, 120]
      m_GestionnaireVHost.Initialisation(m_structureProjet.P_RepConf + "\vhosts.conf", m_Journal)
      
      
      m_systeme			= new CLSysteme
      
      
      // Remplacement du lecteur INI
      m_Configuration		= allouer un CLConfiguration
      m_Configuration.Initialisation(m_structureProjet.P_RepConf + "\config.conf", m_Journal)
      
      // Initialisation de la BDD
      m_Base = allouer un CLBase
      m_Base.Initialisation(m_Configuration, m_Journal) 
      
      // Configuration du Serveur
      m_ServeurSocket								= allouer un CLServeurSocket
      m_ServeurSocket.m_ProcedureRappel				= MessageRecu
      m_ServeurSocket.P_PortSocket				= Val(m_Configuration.LireParametre("Serveur", "Port", "8080"))
      m_ServeurSocket.P_CheminPhpCgi				= m_Configuration.LireParametre("Serveur", "CheminPhpCgi", "")
      m_ServeurSocket.p_NomSocketEcoute			= "SocketRaaD"
      m_ServeurSocket.P_CLconfiguration           = m_Configuration
     type : 458752
   -
     name : _LireEnregistrement
     procedure_id : 1473736444733868589
     type_code : 12
     code : |1+
      procédure prive _LireEnregistrement(L_RequeteHttp est CLCanalSocket)
      
      // Affectation par copie 
      
      L_EnregistrementCourant est  clenregistrement
      L_EnregistrementCourant <= m_Base.m_Table[L_RequeteHttp.m_Parametres["table"]]
      
      L_EnregistrementCourant.Charger(L_RequeteHttp.m_Parametres["valkey"],L_RequeteHttp.m_Parametres["condition"])
      
      si L_EnregistrementCourant.m_erreur <> "" ALORS
      	L_RequeteHttp.m_CodeReponse		= "401"
      	L_RequeteHttp.m_ContenuBuffer	= L_EnregistrementCourant.m_erreur
      sinon
      	L_RequeteHttp.m_CodeReponse = "200 OK"
      	L_RequeteHttp.m_ContenuBuffer = L_EnregistrementCourant.m_json
      FIN
      
      
      
     type : 458752
   -
     name : _ExecuterRequeteSQL
     procedure_id : 1473738635167241172
     type_code : 12
     code : |1+
      procédure Privé _ExecuterRequeteSQL(L_RequeteHttp est CLCanalSocket)
      
      
      L_BaseDonneesClone est CLBase dynamique = allouer CLBase
      L_BaseDonneesClone <= m_Base
      
      ChaineRequete est chaine 
      ChaineRequete = L_RequeteHttp.m_Parametres["sql"]
      
      L_RequeteHttp.m_CodeReponse = "200 OK"
     type : 458752

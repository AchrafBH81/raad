   -
     name : Init
     internal_properties : BQAAAAUAAAAcLpBr0K4gYdokgggwYHq/YBDVaIPdjeR1VEo/vzFcOGRJ3cJSZZ8PG6l3iF2SwOIJ5Kz9k7gF+y7kHyJ9kOiyf4Gl6ZSxsH3J0o4OXMu3LZ/R6PhT8uLCOdoLDGeu/5VyBBzyGltKMtMa629WkCiEXPdkF9BB3bcZIms8d/TFHbUUK8MzJhfF8wS+fXWDR63qNdSJuQ==
     procedure_id : 1891210886552515520
     type_code : 12
     code : |1+
      procédure Init(a_table est une chaîne)
      
      // on initialise la classe avec le nom de la table 
      
      // Extraction de la structure de la table 
      
      m_table = a_table
      indrub est un entier
      
      l_ResRub est une chaîne = HListeClé(m_table,hLstDétailPlus)
      l_nomRub est une chaine  
      
      POUR TOUTE CHAÎNE l_rub DE l_ResRub SEPAREE PAR RC
      	
      	POUR TOUTE CHAÎNE l_desRub de l_rub SEPAREE PAR TAB
      		selon indrub
      			
      			cas 0 : l_nomRub = l_desRub
      			
      			cas 4 : SI Val(l_desRub) = 1  ALORS m_key = l_nomRub
      		FIN
      		
      		 
      		indrub++ 
      		si indrub = 5 ou m_key <> "" alors sortir 
      	FIN
      
      	si m_key <> "" ALORS SORTIR
      FIN
      //// déclaration dynamique de l'enregistrement 
      //Trace(m_enrg..FichierAssocié)
      //l_codeDynamique  est chaine = [
      //e_%1 est un Enregistrement de %1 
      //hlitpremier(wbarticle)
      //]
      //l_codeDynamique = ChaîneConstruit(l_codeDynamique,m_table)
      //
      //ExécuteCode(l_codeDynamique)
      
      
      
      CAS ERREUR:
      m_base.Déconnexion()
      m_erreur = ErreurInfo()
      
      
      
      CAS EXCEPTION:
      m_base.Déconnexion()
      m_erreur = ExceptionInfo()
      
     type : 458752
   -
     name : Charger
     procedure_id : 1891210886552581056
     type_code : 12
     code : |1-
      procédure Charger(local a_valkey est une chaîne, a_condition est une chaîne)
      
      m_valkey	= a_valkey
      m_condition	= a_condition
      
      LOCAL
      	L_ReqSQL			est une source de données
      	L_ResEnregistrement	est un Enregistrement 
      	
      
      SI m_valkey <> "" ALORS
      	m_RequeteSQL = ChaîneConstruit("SELECT * FROM %1 where %2" , m_table, m_key + " = " + m_valkey )
      SINON
      	m_RequeteSQL = ChaîneConstruit("SELECT * FROM %1 where %2" , m_table, m_condition ) 
      FIN
      
      m_base.Connexion()
      HExécuteRequêteSQL(L_ReqSQL,m_base.m_connexion,hRequêteSansCorrection,m_RequeteSQL)
      // lire le premier enregistrement  
      HLitPremier(L_ReqSQL)
      FichierVersMémoire(L_ResEnregistrement,L_ReqSQL)
      HAnnuleDéclaration(L_ReqSQL)
      
      //Sérialisation de l’enregistrement 
      Sérialise(L_ResEnregistrement,m_json,psdJSON)
      
      
      CAS ERREUR:
      m_base.Déconnexion()
      m_erreur = ErreurInfo()
      
      
      
      CAS EXCEPTION:
      m_base.Déconnexion()
      m_erreur = ExceptionInfo()
      
      
      FIN :
      m_base.Déconnexion()
     type : 458752
   -
     name : Modifier
     procedure_id : 1891210886552646592
     type_code : 12
     code : |1+
      
      
      procédure Modifier()
      // [ARCHITECTURE RAAD : SÉCURITÉ ANTI-INJECTION SQL]
      // RÈGLE ABSOLUE : Zéro concaténation de valeurs clientes dans les requêtes SQL.
      // Nous utilisons une variable de type 'Source de Données' couplée à hRequêteDéfaut.
      // L'affectation dynamique des paramètres se fait via indirection : 
      // {"MaSource.MonParametre"} = Valeur. Le moteur HFSQL gère le typage et l'échappement.
      
      
      LOCAL
      	l_SourceRequete		est une Source de Données
      	l_DonneesJson		est un Variant
      	l_ClauseWhere		est une chaîne
      	l_CorpsReq			est une chaîne
      	l_NomParametre		est une chaîne
      	
      // 1. Initialisation et Connexion
      m_base.Connexion()
      
      l_DonneesJson	= JSONVersVariant(m_json)
      
      // 2. Construction de l'ossature SQL paramétrée
      m_RequeteSQL	= "UPDATE " + m_table + RC + "SET "
      
      POUR TOUT l_Ligne DE l_DonneesJson
      	
      	// Création d'un nom de paramètre unique (ex: p_Prix)
      	l_NomParametre = "p_" + l_Ligne..Nom
      	
      	SI l_Ligne..Nom = m_key ALORS
      		l_ClauseWhere = "WHERE " + l_Ligne..Nom + " = {" + l_NomParametre + "}"
      	SINON
      		// Ajoute automatiquement la virgule si l_CorpsReq n'est pas vide
      		l_CorpsReq += [", " + RC] + l_Ligne..Nom + " = {" + l_NomParametre + "}"
      	FIN
      	
      	// 3. SECRÉTAIRE ANTI-INJECTION : Affectation de la valeur en tant que PARAMÈTRE
      	// L'indirection crée la propriété de paramètre à la volée sur la source de données.
      	// Équivaut à taper : l_SourceRequete.p_Prix = 10
      	{"l_SourceRequete." + l_NomParametre} = l_Ligne..Valeur
      FIN
      
      // 4. Assemblage final de la requête SQL paramétrée
      m_RequeteSQL += RC + l_CorpsReq + RC + l_ClauseWhere
      
      // 5. Exécution sécurisée
      // La constante hRequêteDéfaut indique à HFSQL d'analyser la chaîne, d'y repérer 
      // les variables {...} et de les lier aux paramètres affectés à l_SourceRequete.
      SI PAS HExécuteRequêteSQL(l_SourceRequete, m_base.m_connexion, hRequêteDéfaut, m_RequeteSQL) ALORS
      	m_erreur = ErreurInfo()
      FIN
      
      
      CAS ERREUR:
      m_erreur = ErreurInfo()
      
      CAS EXCEPTION:
      m_erreur = ExceptionInfo()
      
      FIN :
      // Exécuté dans tous les cas
      m_base.Déconnexion()
     type : 458752
   -
     name : Creer
     procedure_id : 1891210886552712128
     type_code : 12
     code : |1-
      procédure Creer()
      
      HRAZ(m_table)
      {m_table,indFichier} = _JsonVersEnregistrement()
      HAjoute(m_table,hAffecteParcours)
      
      l_enrg est un Enregistrement = {m_table,indFichier}
      Sérialise(l_enrg,m_json,psdJSON)
      
      
      CAS ERREUR:
      m_base.Déconnexion()
      m_erreur = ErreurInfo()
      
      
      
      CAS EXCEPTION:
      m_base.Déconnexion()
      m_erreur = ExceptionInfo()
      
      
      FIN :
      m_base.Déconnexion()
     type : 458752
   -
     name : _JsonVersEnregistrement
     procedure_id : 1891210886552777664
     type_code : 12
     code : |1+
      procédure privée _JsonVersEnregistrement():Enregistrement
      
      VariantEnregistrement		est un variant	= JSONVersVariant(m_json)
      NouvelEnregistrement	est un Enregistrement
      NouvelEnregistrement = {m_table}
      
      POUR i=1 _a_ VariantEnregistrement..Membre..Occurrence
      	{"E_record."+VariantEnregistrement..Membre[i]..Nom} = VariantEnregistrement..Membre[i]..Valeur 	
      FIN
      
      renvoyer NouvelEnregistrement
     type : 458752

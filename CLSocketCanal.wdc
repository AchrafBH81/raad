 code_elements :
  type_code : 10
  p_codes :
   -
     code : |1+
      CLCanalSocket est une Classe
      	m_configuration			est CLConfiguration dynamique
      	m_NomSocket				est chaine 
      	m_AdresseClient			est chaîne
      	m_MessageSocketRecu		est chaine 
      	m_MessageSocketReponse	est chaine 
      	m_CanalOuvert			est un booléen
      	
      	m_UrlRecue			est une chaîne
      	m_PointDentre			est une chaîne 		
      	m_CorpsReq				est une chaîne 
      	m_HeaderReq				est une chaîne 
      	m_TypeReq				est une chaîne
      	m_PositionUrl			est un entier
      	m_extension				est une chaîne 
      	m_Gzip					est un booléen
      	m_ContenuBuffer			est un Buffer
      	m_CodeReponse			est un chaîne
      	m_Parametres			est un tableau associatif de chaînes
      	m_RepEXe				est une chaîne
      	
      		
      		
      fin
     type : 131072
  procedures :
   -
     name : Constructeur
     procedure_id : 1891211195790953650
     type_code : 27
     code : |1+
      procédure Constructeur(a_Clonfiguration est CLConfiguration)
      
      m_configuration = a_Clonfiguration
      m_CanalOuvert	= vrai
     type : 589824
   -
     name : Destructeur
     procedure_id : 1891211195791019186
     type_code : 28
     code : |1+
      procédure Destructeur()
      
     type : 655360
   -
     name : AnalyseReq
     procedure_id : 1891211195791084722
     type_code : 12
     code : |1+
      procédure AnalyseReq()
      
      m_HeaderReq		= Décode(m_MessageSocketRecu[[ À Position(m_MessageSocketRecu,RC+RC)-1]],encodeURLVersUTF8)
      m_CorpsReq		= Décode(m_MessageSocketRecu[[Position(m_MessageSocketRecu,RC+RC)+4 À ]],encodeURLVersUTF8)
      m_PositionUrl	= Position(m_HeaderReq,"/")
      m_TypeReq		= SansEspace(m_HeaderReq[1 À m_PositionUrl-1])
      m_UrlRecue		= SansEspace(m_HeaderReq[[m_PositionUrl+1 À Position(m_HeaderReq,"HTTP",m_PositionUrl)-1]])
      m_PointDentre	= Minuscule( m_UrlRecue[[  À Position(m_UrlRecue,"/")-1 ]])
      
      _GetParam()
     type : 458752
   -
     name : _GetParam
     procedure_id : 1891211195791150258
     type_code : 12
     code : |1-
      procédure privée _GetParam()
      Local
      L_indicePosition	est un entier
      
      
      //Récupérer les paramètres passés dans l'URL
      UrlParametre	est chaine	= m_UrlRecue[[ Position(m_UrlRecue,"?")+1 À]]
      POUR TOUTE CHAÎNE souschaine DE UrlParametre SÉPARÉE PAR "&"
      	L_indicePosition = Position(souschaine,"=")
      	SI L_indicePosition ALORS
      		m_Parametres[SansEspace(souschaine[[ À L_indicePosition-1]])] = SansEspace(souschaine[[L_indicePosition+1 À ]])
      	FIN	
      FIN
      
      
      //Récupérer les paramètres passés dans l'en-tête.
      POUR TOUTE CHAÎNE souschaine DE m_HeaderReq SÉPARÉE PAR rc
      	L_indicePosition = Position(souschaine,":")	
      	SI L_indicePosition ALORS
      		m_Parametres[SansEspace(souschaine[[ À L_indicePosition-1]])] = SansEspace(souschaine[[L_indicePosition+1 À ]])	
      	FIN
      FIN
     type : 458752
   -
     name : _GenerateHeaderMessage
     procedure_id : 1891211195791215794
     type_code : 12
     code : |1+
      procédure privée _GenerateHeaderMessage()<métier> : chaîne
      
      //génération de l'en-tête de la réponse HTTP
      l_valeur est une chaîne=[
      HTTP/1.1 %1
      Accept-Ranges:bytes
      Content-Length:%2
      Server:RaaD 1.2
      Date:%3
      Connection:Keep-Alive
      ]
      
      l_DateServer est une dateheure = DateHeureLocaleVersUTC(DateHeureSys())
      
      l_valeur = ChaîneConstruit(l_valeur,m_CodeReponse,Taille(m_ContenuBuffer), DateVersChaîne(l_DateServer.PartieDate,"JJ MMM AAAA" )+ " "+HeureVersChaîne(l_DateServer.PartieHeure,"HH:MM:SS")+" GMT")
      l_valeur += [RC] + m_configuration.m_TabExtensions[m_Extension]
      
      SI m_Gzip ALORS  l_valeur += [RC] + "Content-Encoding:Gzip"
      
      
      RENVOYER l_valeur
      
     type : 458752
   -
     name : GetReponse
     procedure_id : 1891211195791281330
     type_code : 12
     code : |1+
      procédure GetReponse()
      
      m_MessageSocketReponse =  _GenerateHeaderMessage() + RC + RC + m_ContenuBuffer
      
     type : 458752
   -
     name : GetFile
     internal_properties : BQAAAAUAAAD36zHHNzqf1YsqeKhuAost9QyLwtABFfotENHsY2gZ1tIU31foK+W8B+1m+nSsxbHfm/GkZcbbPfhdiIe+tbDcWiNV06NQpF7AYcpRx8WSEW3D21cMjgb70UHvmaq+VJnA8JlXt5UwyTVd2ci9xpX8Trv96APNobyVszOFLo7Ane9K+sJcAL0SB11kzofqtIhi5g==
     procedure_id : 1891211195791346866
     type_code : 12
     code : |1+
      procédure publique  GetFile() <métier>
      
      m_UrlRecue	= Remplace(m_UrlRecue, "/", "\") // Uniformiser les séparateurs Windows
      m_UrlRecue	= Remplace(m_UrlRecue, "..\", "") // INTERDIRE de remonter d'un dossier
      
      
      
      
      m_CodeReponse = "200 OK"
      
      
      SI m_UrlRecue	 = "" ALORS
      	m_UrlRecue		= "RAAD\index.html"
      	m_Extension	= ".html"
      SINON
      	SI Position(m_UrlRecue,"?") > 1 ALORS  m_UrlRecue = m_UrlRecue[ À Position(m_UrlRecue,"?")-1]
      	m_UrlRecue	= Remplace(m_UrlRecue ,"/","\")
      	m_Extension	= m_UrlRecue[Position(m_UrlRecue,".",0,DepuisFin) À ]
      FIN
      
      
      QUAND EXCEPTION DANS 
      	
      	selon m_extension
      		cas ".php"
      		
      		m_ContenuBuffer = ExecuterPhp(m_configuration.LireParametre("Serveur","CheminPhpCgi",""),fRepExe()+["\"]+"WWW\"+m_UrlRecue)
      		
      		
      		AUTRE CAS
      		m_ContenuBuffer   = fChargeBuffer(fRepExe()+["\"]+"WWW\"+m_UrlRecue)	
      	FIN
      	
      	SI m_ContenuBuffer ="" ALORS 
      		// Code 404 si on ne trouve pas l'élément 
      		m_CodeReponse	= 404
      		m_ContenuBuffer	= m_configuration.m_TabReponse[404]
      	FIN
      	
      	SI m_Extension DANS (".html",".css",".js",".txt",".xml",".json",".csv",".php",".asp",".jsp",".woff",".svg",".woff2",".ttf",".eot","hml") ALORS
      		m_ContenuBuffer	= Compresse(m_ContenuBuffer,compresseGZIP)
      		m_Gzip			= Vrai
      	FIN
      	
      FAIRE
      	// Code 500 
      	m_CodeReponse	= 500
      	m_ContenuBuffer	= m_configuration.m_TabReponse[500]
      	
      FIN
     type : 458752
  procedure_templates : []
  property_templates : []

     name : MemoireDisponibleMo
     procedure_id : 1891525372646791853
     type_code : 15
     code : |1+
      using System;
      using Microsoft.VisualBasic.Devices;
      
      public static long MemoireDisponibleMo()
      {
      ComputerInfo info = new ComputerInfo();
      ulong memLibre = info.AvailablePhysicalMemory;
      return (long)(memLibre / 1024 / 1024);
      }

      using System;
      using Microsoft.VisualBasic.Devices;
      
      
      public static long MemoireTotaleMo()
      {
      ComputerInfo info = new ComputerInfo();
      ulong memTotale = info.TotalPhysicalMemory;
      return (long)(memTotale / 1024 / 1024);
      }

   -
     name : LancerServeurHttpsEntrantAsync
     procedure_id : 1891525372646726317
     type_code : 15
     code : |1+
      using System;
      using System.IO;
      using System.Net;
      using System.Net.Sockets;
      using System.Net.Security;
      using System.Security.Cryptography.X509Certificates;
      using System.Security.Cryptography;
      using System.Threading.Tasks;
      using Org.BouncyCastle.Crypto;
      using Org.BouncyCastle.OpenSsl;
      using Org.BouncyCastle.Security;
      using Org.BouncyCastle.Pkcs;
      using Org.BouncyCastle.X509;
      
      public static async Task LancerServeurHttpsEntrantAsync(
      int portHttps,
      int portHttpDestination,
      string cheminCertPem,
      string cheminClePem
      )
      {
      var certificat = ChargerCertificatDepuisPem(cheminCertPem, cheminClePem);
      var listener = new TcpListener(IPAddress.Any, portHttps);
      listener.Start();
      
      Console.WriteLine("🔐 Serveur HTTPS démarré sur le port " + portHttps + ", redirige vers HTTP sur le port " + portHttpDestination + "...");
      
      while (true)
      {
      var client = await listener.AcceptTcpClientAsync();
      Task.Run(() => GérerClientSslAsync(client, portHttpDestination, certificat));
      }
      }
      
      private static async Task GérerClientSslAsync(TcpClient client, int portHttpDestination, X509Certificate2 certificat)
      {
      using (client)
      using (var destinationClient = new TcpClient("localhost", portHttpDestination))
      {
      var sslStream = new SslStream(client.GetStream(), false);
      try
      {
      await sslStream.AuthenticateAsServerAsync(
      certificat,
      clientCertificateRequired: false,
      enabledSslProtocols: System.Security.Authentication.SslProtocols.Tls12,
      checkCertificateRevocation: false
      );
      }
      catch (Exception ex)
      {
      Console.WriteLine("❌ Erreur SSL lors de la connexion client : " + ex.Message);
      return;
      }
      
      var destinationStream = destinationClient.GetStream();
      
      try
      {
      Console.WriteLine("✅ Connexion SSL acceptée → redirection HTTP en cours...");
      
      var t1 = sslStream.CopyToAsync(destinationStream);
      var t2 = destinationStream.CopyToAsync(sslStream);
      
      await Task.WhenAny(t1, t2);
      }
      catch (Exception ex)
      {
      Console.WriteLine("❌ Erreur de redirection des flux : " + ex.Message);
      }
      }
      }
      
      private static X509Certificate2 ChargerCertificatDepuisPem(string cheminCertPem, string cheminClePem)
      {
      Org.BouncyCastle.X509.X509Certificate bcCert;
      using (var certReader = File.OpenText(cheminCertPem))
      {
      var pemReader = new PemReader(certReader);
      bcCert = (Org.BouncyCastle.X509.X509Certificate)pemReader.ReadObject();
      }
      
      AsymmetricKeyParameter key;
      using (var keyReader = File.OpenText(cheminClePem))
      {
      var pemReader = new PemReader(keyReader);
      object keyObject = pemReader.ReadObject();
      
      if (keyObject is AsymmetricCipherKeyPair)
      key = ((AsymmetricCipherKeyPair)keyObject).Private;
      else if (keyObject is AsymmetricKeyParameter)
      key = (AsymmetricKeyParameter)keyObject;
      else
      throw new Exception("Format de clé non reconnu.");
      }
      
      var storeBuilder = new Pkcs12StoreBuilder();
      var store = storeBuilder.Build();
      
      var certEntry = new X509CertificateEntry(bcCert);
      string alias = "cert-localhost";
      store.SetCertificateEntry(alias, certEntry);
      store.SetKeyEntry(alias, new AsymmetricKeyEntry(key), new[] { certEntry });
      
      using (var ms = new MemoryStream())
      {
      store.Save(ms, new char[0], new SecureRandom());
      return new X509Certificate2(ms.ToArray(), "", X509KeyStorageFlags.Exportable);
      }
      }

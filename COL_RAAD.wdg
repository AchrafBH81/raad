     name : ExecuterPhp
     procedure_id : 1891525372646660781
     type_code : 15
     code : |1+
      using System;
      using System.Diagnostics;
      using System.IO;
      using System.Text; 
      
      public static string ExecuterPhp(string phpCgiPath, string phpFilePath)
      {
      try
      {
      string argument = "\"" + phpFilePath + "\"";
      
      ProcessStartInfo startInfo = new ProcessStartInfo("\"" + phpCgiPath + "\"")
      {
      Arguments = argument,
      UseShellExecute = false,
      RedirectStandardOutput = true,
      CreateNoWindow = true
      };
      
      using (Process process = Process.Start(startInfo))
      {
      using (StreamReader reader = process.StandardOutput)
      {
      StringBuilder output = new StringBuilder();
      bool contentStarted = false;
      
      while (!reader.EndOfStream)
      {
      string line = reader.ReadLine();
      
      // Vérifie si le contenu HTML commence
      if (string.IsNullOrWhiteSpace(line))
      {
      contentStarted = true;
      continue;
      }
      
      if (contentStarted)
      {
      output.AppendLine(line);
      }
      }
      
      process.WaitForExit();
      
      return output.ToString();
      }
      }
      }
      catch (Exception ex)
      {
      return "Erreur lors de l'exécution du script PHP : " + ex.Message;
      }
      }

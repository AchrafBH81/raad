  p_codes :
   -
     code : |1+
      CLGestionnaireVHost est une Classe
      PRIVÉ
      	m_tabVHosts		est un tableau associatif de chaînes
      	m_FichierConf	est une chaîne
      	m_log			est CLlog dynamique
      FIN
      
     type : 131072
  procedures :
